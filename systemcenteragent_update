#Requires -Version 5.0

<#

.SYNOPSIS

    Stops and restarts the OpenText (Open Text) System Center Agent on remote

    servers, then validates agent connectivity to patch.dacs.dla.mil:443.

 

.DESCRIPTION

    - Reads servers.txt organized by zone headers [ZoneName]

    - Auto-elevates to Administrator via UAC if not already elevated

    - Uses the SC API over RPC (same method as services.msc) — no WinRM or

      WMI required. Works with any account that has rights to manage services

      remotely via the Services console.

    - Resolves agent log path via the remote registry (HKLM) over named pipe,

      which uses the same RPC channel as the Services console.

    - Scans agent logs post-restart for successful connection to patch.dacs.dla.mil:443

    - Writes a timestamped log file and opens it in Notepad on completion

 

.NOTES

    servers.txt format (place in same folder as script):

        [Zone1-Production]

        server01

        server02

 

        [Zone2-DR]

        server03

        # Lines starting with # are ignored

 

    Requirements:

        - PowerShell 5.0+

        - Executing account must have rights to manage services remotely

          (same rights needed to use services.msc against remote servers)

        - TCP port 135 and dynamic RPC ports must be open to target servers

        - Admin$ share must be accessible for UNC log file reads

        - Remote Registry service must be running on target servers for log

          path resolution (fallback UNC paths used if registry is unavailable)

 

    Adjustable settings are in the Configuration block below.

#>

 

# ══════════════════════════════════════════════════════════════════════════════

# CONFIGURATION

# ══════════════════════════════════════════════════════════════════════════════

$ServersFile    = ".\servers.txt"           # Path to server list

$ServiceName    = "OTSystemCenterAgent"     # OpenText System Center Agent service name

$TimeoutSec     = 60                        # Max seconds to wait per service stop/start

$AgentWaitSec   = 30                        # Seconds to wait after restart before reading agent logs

$SuccessPattern = "patch\.dacs\.dla\.mil:443"  # Expected connection string in agent log

$ErrorPatterns  = @("error","fail","unable","timeout","refused","cannot connect")

$LogFile        = ".\RestartAgent_$(Get-Date -Format 'yyyyMMdd_HHmmss').log"

# ══════════════════════════════════════════════════════════════════════════════

 

# ── Auto-Elevate to Administrator ─────────────────────────────────────────────

if (-not ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)) {

    Write-Host "Not running as Administrator. Relaunching elevated..." -ForegroundColor Yellow

    Start-Process powershell.exe -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$($MyInvocation.MyCommand.Definition)`"" -Verb RunAs

    exit

}

 

# ── Logging ───────────────────────────────────────────────────────────────────

function Write-Log {

    param([string]$Message, [string]$Level = "INFO")

    $entry = "[{0}] [{1}] {2}" -f (Get-Date -Format "yyyy-MM-dd HH:mm:ss"), $Level, $Message

    $entry | Tee-Object -FilePath $LogFile -Append | Write-Host -ForegroundColor $(

        switch ($Level) {

            "ERROR"   { "Red"    }

            "WARN"    { "Yellow" }

            "SUCCESS" { "Green"  }

            default   { "Cyan"   }

        }

    )

}

 

# ── Resolve Log Path via Remote Registry ──────────────────────────────────────

function Get-AgentInstallDir {

    param([string]$Server, [string]$Zone)

 

    # The remote registry is accessed over the same RPC/named-pipe channel used

    # by services.msc — no WMI or WinRM needed. The service ImagePath stored in

    # HKLM\SYSTEM\CurrentControlSet\Services\<name> gives us the binary location

    # from which we derive the install directory and likely log paths.

    try {

        $reg     = [Microsoft.Win32.RegistryKey]::OpenRemoteBaseKey('LocalMachine', $Server)

        $svcKey  = $reg.OpenSubKey("SYSTEM\CurrentControlSet\Services\$ServiceName")

 

        if (-not $svcKey) {

            Write-Log "[$Zone] $Server - WARN: Service key not found in remote registry. Falling back to UNC guesses." "WARN"

            return $null

        }

 

        $imagePath  = $svcKey.GetValue("ImagePath") -replace '"', '' -replace '%SystemRoot%', 'C:\Windows'

        $svcKey.Close()

        $reg.Close()

 

        $installDir = Split-Path $imagePath -Parent

        Write-Log "[$Zone] $Server - Registry ImagePath : $imagePath"

        Write-Log "[$Zone] $Server - Resolved install dir: $installDir"

        return $installDir

 

    } catch {

        Write-Log "[$Zone] $Server - WARN: Remote registry query failed ($($_.Exception.Message)). Falling back to UNC guesses." "WARN"

        return $null

    }

}

 

# ── Service Restart ───────────────────────────────────────────────────────────

function Restart-AgentOnServer {

    param([string]$Server, [string]$Zone)

 

    Write-Log "[$Zone] Processing server: $Server"

 

    # ── Ping Check ────────────────────────────────────────────────────────────

    Write-Log "[$Zone] $Server - Testing network connectivity..."

    if (-not (Test-Connection -ComputerName $Server -Count 2 -Quiet)) {

        Write-Log "[$Zone] $Server - CONNECTION ERROR: Host unreachable (ping failed). Skipping." "ERROR"

        return [PSCustomObject]@{ Server=$Server; Zone=$Zone; Status="Unreachable - Ping Failed" }

    }

    Write-Log "[$Zone] $Server - Ping OK." "SUCCESS"

 

    # ── Service Lookup ────────────────────────────────────────────────────────

    # Get-Service with -ComputerName uses the SC API over RPC — the same

    # underlying method as the Windows Services console (services.msc).

    # No WinRM or WMI is involved. Works as long as RPC port 135 is reachable

    # and the account has remote service management rights.

    try {

        $svc = Get-Service -ComputerName $Server -Name $ServiceName -ErrorAction SilentlyContinue

 

        if (-not $svc) {

            Write-Log "[$Zone] $Server - Exact service name '$ServiceName' not found. Searching by wildcard..." "WARN"

            $svc = Get-Service -ComputerName $Server -ErrorAction Stop | Where-Object {

                $_.DisplayName -like "*OpenText*"            -or

                $_.DisplayName -like "*Open Text*"           -or

                $_.DisplayName -like "*System Center*"       -or

                $_.DisplayName -like "*System Center Agent*" -or

                $_.Name        -like "*OT*"                  -or

                $_.Name        -like "*SystemCenter*"        -or

                $_.Name        -like "*SysCenter*"

            }

            if ($svc) {

                Write-Log "[$Zone] $Server - Found matching service(s): $(($svc | ForEach-Object { "'$($_.Name)' [$($_.DisplayName)]" }) -join ', ')" "WARN"

                Write-Log "[$Zone] $Server - Update `$ServiceName in the config block to the correct name. Skipping." "WARN"

                return [PSCustomObject]@{ Server=$Server; Zone=$Zone; Status="Service Name Mismatch - See Log" }

            } else {

                Write-Log "[$Zone] $Server - ERROR: No OpenText/System Center service found. Is the agent installed?" "ERROR"

                return [PSCustomObject]@{ Server=$Server; Zone=$Zone; Status="Service Not Found" }

            }

        }

 

        # ── Stop ──────────────────────────────────────────────────────────────

        if ($svc.Status -ne 'Stopped') {

            Write-Log "[$Zone] $Server - STOP INITIATED: '$ServiceName' is currently '$($svc.Status)'."

            Stop-Service -InputObject $svc -Force -ErrorAction Stop

            $svc.WaitForStatus('Stopped', (New-TimeSpan -Seconds $TimeoutSec))

            $svc.Refresh()

            if ($svc.Status -eq 'Stopped') {

                Write-Log "[$Zone] $Server - STOP SUCCESS: '$ServiceName' is now 'Stopped'." "SUCCESS"

            } else {

                Write-Log "[$Zone] $Server - STOP WARNING: '$ServiceName' status is '$($svc.Status)' after stop attempt." "WARN"

            }

        } else {

            Write-Log "[$Zone] $Server - STOP SKIPPED: '$ServiceName' was already 'Stopped'." "WARN"

        }

 

        # ── Start ─────────────────────────────────────────────────────────────

        Write-Log "[$Zone] $Server - START INITIATED: Starting '$ServiceName'..."

        Start-Service -InputObject $svc -ErrorAction Stop

        $svc.WaitForStatus('Running', (New-TimeSpan -Seconds $TimeoutSec))

        $svc.Refresh()

        if ($svc.Status -eq 'Running') {

            Write-Log "[$Zone] $Server - START SUCCESS: '$ServiceName' is now 'Running'." "SUCCESS"

        } else {

            Write-Log "[$Zone] $Server - START WARNING: '$ServiceName' status is '$($svc.Status)' after start attempt." "WARN"

            return [PSCustomObject]@{ Server=$Server; Zone=$Zone; Status="Start Warning: $($svc.Status)" }

        }

 

        return [PSCustomObject]@{ Server=$Server; Zone=$Zone; Status="Restarted" }

 

    } catch [System.ServiceProcess.TimeoutException] {

        Write-Log "[$Zone] $Server - TIMEOUT ERROR: Service did not change state within ${TimeoutSec}s. The service may be hung. Consider increasing `$TimeoutSec." "ERROR"

        return [PSCustomObject]@{ Server=$Server; Zone=$Zone; Status="Timeout" }

    } catch {

        Write-Log "[$Zone] $Server - ERROR: $($_.Exception.Message)" "ERROR"

        return [PSCustomObject]@{ Server=$Server; Zone=$Zone; Status="Error: $($_.Exception.Message)" }

    }

}

 

# ── Agent Log Check ───────────────────────────────────────────────────────────

function Read-AgentLog {

    param([string]$Server, [string]$Zone)

 

    Write-Log ""

    Write-Log "[$Zone] Checking agent log on: $Server"

 

    # Attempt to resolve install dir from remote registry first.

    # Falls back to common UNC guesses if the Remote Registry service is

    # not running or the key is not accessible.

    $installDir = Get-AgentInstallDir -Server $Server -Zone $Zone

    $parentDir  = if ($installDir) { Split-Path $installDir -Parent } else { $null }

 

    if ($installDir) {

        $candidatePaths = @(

            "$installDir\Logs\agent.log",

            "$installDir\Logs\SystemCenterAgent.log",

            "$installDir\log\agent.log",

            "$installDir\log\SystemCenterAgent.log",

            "$parentDir\Logs\agent.log",

            "$parentDir\Logs\SystemCenterAgent.log"

        )

    } else {

        # Fallback: common default install locations

        $candidatePaths = @(

            "C:\Program Files\OpenText\System Center Agent\Logs\agent.log",

            "C:\Program Files\OpenText\System Center\Logs\agent.log",

            "C:\Program Files (x86)\OpenText\System Center Agent\Logs\agent.log",

            "C:\Program Files (x86)\OpenText\System Center\Logs\agent.log",

            "C:\ProgramData\OpenText\System Center\Logs\agent.log"

        )

        Write-Log "[$Zone] $Server - Using fallback UNC path list." "WARN"

    }

 

    $logFound = $false

    foreach ($remotePath in $candidatePaths) {

        $uncPath = "\\$Server\" + $remotePath.Replace(":\", "$\")

 

        if (Test-Path $uncPath -ErrorAction SilentlyContinue) {

            $logFound = $true

            Write-Log "[$Zone] $Server - Found agent log: $uncPath"

 

            # Read last 200 lines — enough to capture activity since restart

            $logLines = Get-Content $uncPath -Tail 200 -ErrorAction SilentlyContinue

 

            if (-not $logLines) {

                Write-Log "[$Zone] $Server - Log file exists but is empty or unreadable." "WARN"

                break

            }

 

            # ── Success Check ─────────────────────────────────────────────────

            $successLines = $logLines | Select-String -Pattern $SuccessPattern

            if ($successLines) {

                Write-Log "[$Zone] $Server - SUCCESS: Connected to patch.dacs.dla.mil:443" "SUCCESS"

                $successLines | ForEach-Object { Write-Log "[$Zone] $Server -   >> $($_.Line.Trim())" "SUCCESS" }

            } else {

                Write-Log "[$Zone] $Server - WARNING: No successful connection to patch.dacs.dla.mil:443 detected." "WARN"

                Write-Log "[$Zone] $Server -   Agent may still be initializing, or a firewall may be blocking patch.dacs.dla.mil:443." "WARN"

            }

 

            # ── Error Check ───────────────────────────────────────────────────

            $errorLines = $logLines | Select-String -Pattern ($ErrorPatterns -join "|")

            if ($errorLines) {

                Write-Log "[$Zone] $Server - Connection-related errors found in agent log:" "ERROR"

                $errorLines | ForEach-Object { Write-Log "[$Zone] $Server -   >> $($_.Line.Trim())" "ERROR" }

            } else {

                Write-Log "[$Zone] $Server - No connection errors detected in agent log." "SUCCESS"

            }

 

            break

        }

    }

 

    if (-not $logFound) {

        Write-Log "[$Zone] $Server - WARNING: Agent log not found. Paths checked:" "WARN"

        $candidatePaths | ForEach-Object { Write-Log "[$Zone] $Server -   Tried: $_" "WARN" }

        Write-Log "[$Zone] $Server -   Confirm the log location manually on the server." "WARN"

    }

}

 

# ══════════════════════════════════════════════════════════════════════════════

# MAIN

# ══════════════════════════════════════════════════════════════════════════════

 

if (-not (Test-Path $ServersFile)) {

    Write-Log "servers.txt not found at path: $ServersFile" "ERROR"

    exit 1

}

 

Write-Log "Starting OpenText System Center Agent restart job."

Write-Log "Server list : $ServersFile"

Write-Log "Service name: $ServiceName"

Write-Log "Log file    : $LogFile"

 

$results     = @()

$currentZone = "Unknown"

 

foreach ($line in Get-Content $ServersFile) {

    $line = $line.Trim()

    if ([string]::IsNullOrWhiteSpace($line) -or $line.StartsWith('#')) { continue }

 

    if ($line -match '^\[(.+)\]$') {

        $currentZone = $Matches[1]

        Write-Log ""

        Write-Log "═══ Zone: $currentZone ═══"

        continue

    }

 

    $results += Restart-AgentOnServer -Server $line -Zone $currentZone

}

 

# ── Restart Summary ───────────────────────────────────────────────────────────

Write-Log ""

Write-Log "══════════════ RESTART SUMMARY ══════════════"

$results | Format-Table -AutoSize | Out-String | ForEach-Object { Write-Log $_ }

 

$restarted = ($results | Where-Object Status -eq "Restarted").Count

$failed    = ($results | Where-Object Status -ne "Restarted").Count

Write-Log "Total Servers : $($results.Count)"

Write-Log "Restarted     : $restarted" "SUCCESS"

if ($failed -gt 0) { Write-Log "Failed/Skipped: $failed" "WARN" }

 

# ── Connection Error Summary ──────────────────────────────────────────────────

Write-Log ""

Write-Log "Scanning script log for connection errors..."

$connErrors = Select-String -Path $LogFile -Pattern "CONNECTION ERROR"

if ($connErrors) {

    Write-Host "`n══════════════ CONNECTION ERRORS FOUND ══════════════" -ForegroundColor Red

    $connErrors | ForEach-Object { Write-Host $_.Line -ForegroundColor Red }

    Write-Host "═════════════════════════════════════════════════════`n" -ForegroundColor Red

} else {

    Write-Log "No connection errors detected." "SUCCESS"

}

 

# ── Agent Log Validation ──────────────────────────────────────────────────────

Write-Log ""

Write-Log "Waiting ${AgentWaitSec}s for agents to initialize before reading logs..."

Start-Sleep -Seconds $AgentWaitSec

 

Write-Log ""

Write-Log "══════════════ AGENT CONNECTION LOG CHECK ══════════════"

foreach ($result in ($results | Where-Object Status -eq "Restarted")) {

    Read-AgentLog -Server $result.Server -Zone $result.Zone

}

Write-Log "══════════════ AGENT LOG CHECK COMPLETE ══════════════"

 

# ── Open Log ──────────────────────────────────────────────────────────────────

Write-Log ""

Write-Log "Job complete. Log saved to: $LogFile"

Start-Process notepad.exe -ArgumentList $LogFile

 #==================================================================================

#

#        SCRIPT: Remotely Compress with Multi-Service Control & Rotation (Parallel)

#

#        DESCRIPTION:

#        Stops a LIST of services, compresses a directory, and restarts the

#        original services. Performs backup rotation and logs all actions.

#        Dynamically resolves the instance name, Tomcat service name, and

#        Content Server directory from remote service metadata.

#

#        servers.txt format:

#        - Place in the same directory as this script.

#        - Zones defined using [Zone Name] headers.

#        - One FQDN per line. Instance name is resolved automatically.

#        - Lines starting with # are comments and ignored.

#        - Blank lines are ignored.

#

#        Example servers.txt:

#

#          [Production - Public]

#          prodpub1.domain.com

#          prodpub2.domain.com

#

#          [Production - Private]

#          prodpriv1.domain.com

#

#==================================================================================

 

#region Configuration

$configFile = Join-Path $PSScriptRoot "servers.txt"

if (-not (Test-Path $configFile)) {

    Write-Host "ERROR: Server config file not found: $configFile" -ForegroundColor Red

    Write-Host "Create a 'servers.txt' file in the same directory as this script." -ForegroundColor Yellow

    Write-Host "One FQDN per line. Zone headers: [Zone Name]" -ForegroundColor Yellow

    exit 1

}

 

$logDir          = "C:\Logs"

$localLogPath    = Join-Path $logDir "CompressionLog_$(Get-Date -Format 'yyyyMMdd_HHmmss').log"

$maxParallelJobs = 5

$maxBackups      = 2

$svcStopTimeout  = [TimeSpan]::FromSeconds(60)

$svcStartTimeout = [TimeSpan]::FromSeconds(60)

 

# Stop order: outermost dependents first. Restart is the reverse.

# OTSsystemCenterAgent and Tomcat depend on CS; CS Admin is auxiliary.

$staticServices = @('OTSsystemCenterAgent', '{TOMCAT}', '{INSTANCE}Admin', '{INSTANCE}')

#endregion

 

#region Helpers

function Write-Log {

    param(

        [string]$Message,

        [string]$Level = 'INFO',

        [string]$Color = 'White',

        [switch]$Spacer

    )

    if ($Spacer) {

        Add-Content -Path $localLogPath -Value ''

        Write-Host ''

        return

    }

    $entry = "[$Level] - $(Get-Date -Format 'yyyy-MM-dd HH:mm:ss') - $Message"

    Write-Host $entry -ForegroundColor $Color

    Add-Content -Path $localLogPath -Value $entry

}

 

function Parse-ServersFile {

    param([string]$Path)

    $groups  = [ordered]@{}

    $current = 'Ungrouped'

    $count   = 0

    foreach ($line in (Get-Content $Path)) {

        $t = $line.Trim()

        if ($t -match '^\s*$' -or $t -match '^\s*#') { continue }

        if ($t -match '^\[(.+)\]$') {

            $current = $Matches[1].Trim()

            if (-not $groups.Contains($current)) {

                $groups[$current] = [System.Collections.Generic.List[string]]::new()

            }

            continue

        }

        if (-not $groups.Contains($current)) {

            $groups[$current] = [System.Collections.Generic.List[string]]::new()

        }

        $groups[$current].Add($t)

        $count++

    }

    return $groups, $count

}

#endregion

 

#region Discovery Script Block

$discoverScript = {

    $result = [pscustomobject]@{

        InstanceName      = $null

        TomcatServiceName = $null

        ContentServerDir  = $null

        Errors            = [System.Collections.Generic.List[string]]::new()

    }

 

    try {

        $allSvcs = Get-CimInstance -ClassName Win32_Service -ErrorAction Stop

 

        # Resolve Content Server service (exclude Admin variant)

        $csSvc = $allSvcs | Where-Object {

            $_.Description -like '*Content Server*' -and

            $_.Description -notlike '*Content Server Admin*'

        } | Select-Object -First 1

 

        if ($csSvc) {

            $result.InstanceName = $csSvc.Name

 

            if ($csSvc.PathName) {

                # Strip quotes and args to get bare exe path

                $exePath = $csSvc.PathName -replace '^"([^"]+)".*$', '$1' `

                                           -replace '^([^\s]+\.exe).*$',  '$1'

 

                # Walk up directory tree looking for 'contentserver' folder

                $dir   = Split-Path $exePath -Parent

                $csDir = $null

                for ($i = 0; $i -lt 6; $i++) {

                    if ([IO.Path]::GetFileName($dir) -ieq 'contentserver') {

                        $csDir = $dir; break

                    }

                    $candidate = Join-Path $dir 'contentserver'

                    if (Test-Path $candidate -PathType Container) {

                        $csDir = $candidate; break

                    }

                    $parent = Split-Path $dir -Parent

                    if ($parent -eq $dir) { break }

                    $dir = $parent

                }

 

                if ($csDir) {

                    $result.ContentServerDir = $csDir

                } else {

                    $result.Errors.Add("WARNING: Could not locate 'contentserver' directory from exe path: $($csSvc.PathName)")

                }

            } else {

                $result.Errors.Add("WARNING: Content Server service '$($csSvc.Name)' has no PathName.")

            }

        } else {

            $result.Errors.Add("WARNING: No Content Server service found (excluding Admin).")

        }

 

        # Resolve Tomcat service

        $tomcatSvc = $allSvcs | Where-Object { $_.DisplayName -like '*Apache*Tomcat*' } |

                     Select-Object -First 1

        if ($tomcatSvc) {

            $result.TomcatServiceName = $tomcatSvc.Name

        } else {

            $result.Errors.Add("WARNING: No service matching '*Apache*Tomcat*' found.")

        }

    }

    catch {

        $result.Errors.Add("ERROR during discovery: $_")

    }

 

    return $result

}

#endregion

 

#region Remote Compression Script Block

$scriptBlock = {

    param(

        [string[]]$SvcNames,       # Ordered: stop first → last; restart reversed

        [string]$SrcPath,

        [string]$DestPath,

        [string]$DestFolder,

        [string]$SrcFolderName,

        [int]$MaxBackups,

        [int]$StopTimeoutSec,

        [int]$StartTimeoutSec

    )

 

    $host_ = $env:COMPUTERNAME

 

    function Wait-ServiceStatus {

        param([string]$Name, [string]$Status, [int]$TimeoutSec, [string]$Action)

        $svc     = Get-Service -Name $Name -ErrorAction Stop

        $timeout = [TimeSpan]::FromSeconds($TimeoutSec)

        try {

            $svc.WaitForStatus($Status, $timeout)

            Write-Output "($host_) - Service '$Name' $Action."

        }

        catch [System.ServiceProcess.TimeoutException] {

            throw "Timed out waiting for '$Name' to reach '$Status' after ${TimeoutSec}s."

        }

    }

 

    $stopped = [System.Collections.Generic.List[string]]::new()

 

    try {

        # --- Stop services (in provided order) ---

        foreach ($svcName in $SvcNames) {

            $svc = Get-Service -Name $svcName -ErrorAction SilentlyContinue

            if (-not $svc) {

                Write-Output "($host_) - WARNING: Service '$svcName' not found. Skipping."

                continue

            }

            if ($svc.Status -eq 'Running') {

                Write-Output "($host_) - Stopping '$svcName'..."

                Stop-Service -Name $svcName -Force -ErrorAction Stop

                Wait-ServiceStatus -Name $svcName -Status 'Stopped' `

                    -TimeoutSec $StopTimeoutSec -Action 'stopped'

                $stopped.Add($svcName)

            } else {

                Write-Output "($host_) - '$svcName' already stopped."

            }

        }

 

        # --- Compress ---

        if (-not (Test-Path $SrcPath -PathType Container)) {

            throw "Source path '$SrcPath' does not exist on $host_."

        }

        Write-Output "($host_) - Compressing '$SrcPath' → '$DestPath'..."

        Compress-Archive -Path $SrcPath -DestinationPath $DestPath -Force

        Write-Output "($host_) - Compression completed."

 

        # --- Backup rotation ---

        $backups = Get-ChildItem -Path $DestFolder -Filter "${SrcFolderName}_*.zip" |

                   Sort-Object CreationTime

        $excess  = $backups.Count - $MaxBackups

        if ($excess -gt 0) {

            Write-Output "($host_) - Removing $excess old backup(s) (keeping $MaxBackups)."

            $backups | Select-Object -First $excess | ForEach-Object {

                Remove-Item $_.FullName -Force

                Write-Output "($host_) - Deleted: $($_.Name)"

            }

        } else {

            Write-Output "($host_) - $($backups.Count) backup(s) present. No rotation needed."

        }

    }

    catch { throw $_ }

    finally {

        # --- Restart in reverse stop order ---

        if ($stopped.Count -gt 0) {

            [array]::Reverse($stopped)

            foreach ($svcName in $stopped) {

                try {

                    Write-Output "($host_) - Starting '$svcName'..."

                    Start-Service -Name $svcName -ErrorAction Stop

                    Wait-ServiceStatus -Name $svcName -Status 'Running' `

                        -TimeoutSec $StartTimeoutSec -Action 'started'

                }

                catch {

                    Write-Output "($host_) - ERROR restarting '$svcName': $_"

                }

            }

        }

    }

}

#endregion

 

#region Main

if (-not (Test-Path $logDir)) { New-Item -ItemType Directory -Path $logDir -Force | Out-Null }

 

$startTime = Get-Date

Write-Log "---------------- SCRIPT EXECUTION STARTED ----------------" -Color Cyan

Write-Log "Started   : $($startTime.ToString('yyyy-MM-dd HH:mm:ss'))" -Color Gray

Write-Log "Log file  : $localLogPath" -Color Gray

 

$serverGroups, $totalEntries = Parse-ServersFile -Path $configFile

 

if ($totalEntries -eq 0) {

    Write-Log "ERROR: No valid server entries found in $configFile" -Level 'ERROR' -Color Red

    exit 1

}

 

Write-Log "Servers   : $totalEntries across $($serverGroups.Keys.Count) zone(s)" -Color Gray

Write-Log -Spacer

 

# --- Phase 1: Discovery ---

Write-Log "Phase 1: Discovering service names and paths..." -Color Yellow

$discoveryResults = @{}

 

foreach ($group in $serverGroups.Keys) {

    foreach ($fqdn in $serverGroups[$group]) {

        Write-Log "  Discovering $fqdn..." -Color Gray

        try {

            $disc = Invoke-Command -ComputerName $fqdn -ScriptBlock $discoverScript -ErrorAction Stop

            $discoveryResults[$fqdn] = $disc

            $disc.Errors | ForEach-Object { Write-Log "  ${fqdn}: $_" -Level 'WARN' -Color Yellow }

            Write-Log "  ${fqdn}: Instance='$($disc.InstanceName)'  Tomcat='$($disc.TomcatServiceName)'  CSDir='$($disc.ContentServerDir)'" -Color Gray

        }

        catch {

            Write-Log "  ${fqdn}: Discovery FAILED - $_" -Level 'ERROR' -Color Red

            $discoveryResults[$fqdn] = [pscustomobject]@{

                InstanceName      = $null

