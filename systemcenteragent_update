#==================================================================================
#
#        SCRIPT: System Center Agent Audit (Parallel)
#
#        DESCRIPTION:
#        Evaluates the current state of the System Center (SCOM/OMS) agent
#        across a list of remote servers. For each server, reports:
#          - Content Server instance name (resolved from service metadata)
#          - System Center Agent service status
#          - Installed agent version
#          - All installation path mappings resolved from the service
#
#        servers.txt format:
#        - Place in the same directory as this script.
#        - Zones defined using [Zone Name] headers.
#        - One FQDN per line. Instance name is resolved automatically.
#        - Lines starting with # are comments and ignored.
#        - Blank lines are ignored.
#
#        Example servers.txt:
#
#          [Production - Public]
#          prodpub1.domain.com
#          prodpub2.domain.com
#
#          [Production - Private]
#          prodpriv1.domain.com
#
#==================================================================================

#region Configuration
$configFile = Join-Path $PSScriptRoot "servers.txt"
if (-not (Test-Path $configFile)) {
    Write-Host "ERROR: Server config file not found: $configFile" -ForegroundColor Red
    Write-Host "Create a 'servers.txt' file in the same directory as this script." -ForegroundColor Yellow
    Write-Host "One FQDN per line. Zone headers: [Zone Name]" -ForegroundColor Yellow
    exit 1
}

$logDir          = "C:\Logs"
$localLogPath    = Join-Path $logDir "SCOMAgentAudit_$(Get-Date -Format 'yyyyMMdd_HHmmss').log"
$csvPath         = Join-Path $logDir "SCOMAgentAudit_$(Get-Date -Format 'yyyyMMdd_HHmmss').csv"
$maxParallelJobs = 5
#endregion

#region Helpers
function Write-Log {
    param(
        [string]$Message,
        [string]$Level = 'INFO',
        [string]$Color = 'White',
        [switch]$Spacer
    )
    if ($Spacer) {
        Add-Content -Path $localLogPath -Value ''
        Write-Host ''
        return
    }
    $entry = "[$Level] - $(Get-Date -Format 'yyyy-MM-dd HH:mm:ss') - $Message"
    Write-Host $entry -ForegroundColor $Color
    Add-Content -Path $localLogPath -Value $entry
}

function Parse-ServersFile {
    param([string]$Path)
    $groups  = [ordered]@{}
    $current = 'Ungrouped'
    $count   = 0
    foreach ($line in (Get-Content $Path)) {
        $t = $line.Trim()
        if ($t -match '^\s*$' -or $t -match '^\s*#') { continue }
        if ($t -match '^\[(.+)\]$') {
            $current = $Matches[1].Trim()
            if (-not $groups.Contains($current)) {
                $groups[$current] = [System.Collections.Generic.List[string]]::new()
            }
            continue
        }
        if (-not $groups.Contains($current)) {
            $groups[$current] = [System.Collections.Generic.List[string]]::new()
        }
        $groups[$current].Add($t)
        $count++
    }
    return $groups, $count
}
#endregion

#region Remote Audit Script Block
$auditScript = {
    $result = [pscustomobject]@{
        ComputerName        = $env:COMPUTERNAME
        Zone                = $null   # populated by caller
        ContentServerInstance = $null
        ContentServerDir    = $null
        AgentServiceName    = $null
        AgentDisplayName    = $null
        AgentStatus         = $null
        AgentStartType      = $null
        AgentVersion        = $null
        AgentInstallPath    = $null
        AgentExePath        = $null
        AgentDataPath       = $null
        AgentConfigPath     = $null
        AgentAccountName    = $null
        AgentDescription    = $null
        AgentPID            = $null
        Errors              = [System.Collections.Generic.List[string]]::new()
    }

    try {
        $allSvcs = Get-CimInstance -ClassName Win32_Service -ErrorAction Stop

        #--- Resolve Content Server instance (mirrors existing discovery logic) ---
        $csSvc = $allSvcs | Where-Object {
            $_.Description -like '*Content Server*' -and
            $_.Description -notlike '*Content Server Admin*'
        } | Select-Object -First 1

        if ($csSvc) {
            $result.ContentServerInstance = $csSvc.Name

            if ($csSvc.PathName) {
                $exePath = $csSvc.PathName -replace '^"([^"]+)".*$', '$1' `
                                           -replace '^([^\s]+\.exe).*$', '$1'
                $dir   = Split-Path $exePath -Parent
                $csDir = $null
                for ($i = 0; $i -lt 6; $i++) {
                    if ([IO.Path]::GetFileName($dir) -ieq 'contentserver') {
                        $csDir = $dir; break
                    }
                    $candidate = Join-Path $dir 'contentserver'
                    if (Test-Path $candidate -PathType Container) {
                        $csDir = $candidate; break
                    }
                    $parent = Split-Path $dir -Parent
                    if ($parent -eq $dir) { break }
                    $dir = $parent
                }
                $result.ContentServerDir = if ($csDir) { $csDir } else { 'Not resolved' }
            } else {
                $result.ContentServerDir = 'No PathName on service'
            }
        } else {
            $result.Errors.Add("WARNING: No Content Server service found (excluding Admin).")
        }

        #--- Resolve System Center / SCOM / OMS Agent service ---
        # Searches by known service names and display name patterns
        $agentSvc = $allSvcs | Where-Object {
            $_.Name        -eq 'OTSystemCenterAgent'             -or
            $_.DisplayName -eq 'Open Text System Center Agent'   -or
            $_.Description -like '*Open Text System Center Agent*'
        } | Select-Object -First 1

        if ($agentSvc) {
            $result.AgentServiceName  = $agentSvc.Name
            $result.AgentDisplayName  = $agentSvc.DisplayName
            $result.AgentStatus       = $agentSvc.State          # Running / Stopped / etc.
            $result.AgentStartType    = $agentSvc.StartMode       # Auto / Manual / Disabled
            $result.AgentAccountName  = $agentSvc.StartName
            $result.AgentDescription  = $agentSvc.Description
            $result.AgentPID          = $agentSvc.ProcessId

            #--- Resolve paths from service PathName ---
            if ($agentSvc.PathName) {
                $rawExe = $agentSvc.PathName -replace '^"([^"]+)".*$', '$1' `
                                             -replace '^([^\s]+\.exe).*$', '$1'
                $result.AgentExePath     = $rawExe
                $result.AgentInstallPath = Split-Path $rawExe -Parent

                # Attempt to resolve well-known sub-paths relative to install dir
                $installDir = $result.AgentInstallPath

                $dataCandidates = @(
                    (Join-Path $installDir 'Health Service State'),
                    (Join-Path (Split-Path $installDir -Parent) 'Health Service State'),
                    (Join-Path $installDir 'Data')
                )
                foreach ($c in $dataCandidates) {
                    if (Test-Path $c) { $result.AgentDataPath = $c; break }
                }

                $configCandidates = @(
                    (Join-Path $installDir 'MOMAgent.ini'),
                    (Join-Path $installDir 'AgentCfg.xml'),
                    (Join-Path $installDir 'conf'),
                    (Join-Path (Split-Path $installDir -Parent) 'conf')
                )
                foreach ($c in $configCandidates) {
                    if (Test-Path $c) { $result.AgentConfigPath = $c; break }
                }
            } else {
                $result.Errors.Add("WARNING: Agent service '$($agentSvc.Name)' has no PathName.")
            }

            #--- Resolve installed version from the executable ---
            if ($result.AgentExePath -and (Test-Path $result.AgentExePath)) {
                try {
                    $vi = (Get-Item $result.AgentExePath -ErrorAction Stop).VersionInfo
                    $result.AgentVersion = $vi.FileVersion
                } catch {
                    $result.Errors.Add("WARNING: Could not read file version from '$($result.AgentExePath)': $_")
                }
            }

            #--- Fallback: try registry for version ---
            if (-not $result.AgentVersion) {
                $regPaths = @(
                    'HKLM:\SOFTWARE\Microsoft\Microsoft Operations Manager\3.0\Setup',
                    'HKLM:\SOFTWARE\Microsoft\System Center Operations Manager\12\Setup',
                    'HKLM:\SOFTWARE\Microsoft\System Center\2012\Agent\Setup',
                    'HKLM:\SOFTWARE\WOW6432Node\Microsoft\Microsoft Operations Manager\3.0\Setup'
                )
                foreach ($rp in $regPaths) {
                    if (Test-Path $rp) {
                        $ver = (Get-ItemProperty -Path $rp -ErrorAction SilentlyContinue).AgentVersion
                        if (-not $ver) {
                            $ver = (Get-ItemProperty -Path $rp -ErrorAction SilentlyContinue).CurrentVersion
                        }
                        if ($ver) {
                            $result.AgentVersion = $ver

                            # Also pull install path from registry if not resolved from service
                            if (-not $result.AgentInstallPath) {
                                $regInstall = (Get-ItemProperty -Path $rp -ErrorAction SilentlyContinue).InstallDirectory
                                if ($regInstall) { $result.AgentInstallPath = $regInstall }
                            }
                            break
                        }
                    }
                }
            }

        } else {
            $result.AgentStatus  = 'NOT INSTALLED'
            $result.AgentVersion = 'N/A'
            $result.Errors.Add("WARNING: No System Center Agent service found on this host.")
        }
    }
    catch {
        $result.Errors.Add("ERROR during audit: $_")
    }

    return $result
}
#endregion

#region Main
if (-not (Test-Path $logDir)) { New-Item -ItemType Directory -Path $logDir -Force | Out-Null }

$startTime = Get-Date
Write-Log "---------------- SCOM AGENT AUDIT STARTED ----------------" -Color Cyan
Write-Log "Started  : $($startTime.ToString('yyyy-MM-dd HH:mm:ss'))" -Color Gray
Write-Log "Log file : $localLogPath" -Color Gray
Write-Log "CSV file : $csvPath" -Color Gray

$serverGroups, $totalEntries = Parse-ServersFile -Path $configFile

if ($totalEntries -eq 0) {
    Write-Log "ERROR: No valid server entries found in $configFile" -Level 'ERROR' -Color Red
    exit 1
}

Write-Log "Servers  : $totalEntries across $($serverGroups.Keys.Count) zone(s)" -Color Gray
Write-Log -Spacer

# --- Queue parallel audit jobs ---
Write-Log "Queuing audit jobs (max $maxParallelJobs parallel)..." -Color Yellow

$jobs = [System.Collections.Generic.List[pscustomobject]]::new()

foreach ($group in $serverGroups.Keys) {
    foreach ($fqdn in $serverGroups[$group]) {

        while ((Get-Job -State Running).Count -ge $maxParallelJobs) { Start-Sleep -Milliseconds 500 }

        $job = Invoke-Command -ComputerName $fqdn `
            -ScriptBlock $auditScript `
            -AsJob -ErrorAction SilentlyContinue
        $job.Name = $fqdn

        $jobs.Add([pscustomobject]@{
            Job          = $job
            ComputerName = $fqdn
            GroupName    = $group
        })
    }
}

Write-Log "All $($jobs.Count) job(s) queued. Waiting for completion..." -Color Yellow
$jobs | ForEach-Object { $_.Job } | Wait-Job | Out-Null
Write-Log "All jobs finished. Aggregating results." -Color Yellow
Write-Log -Spacer

# --- Collect results ---
$allResults = [System.Collections.Generic.List[pscustomobject]]::new()
$prevGroup  = $null

foreach ($entry in ($jobs | Sort-Object GroupName, ComputerName)) {

    if ($entry.GroupName -ne $prevGroup) {
        Write-Log "########################################" -Color Magenta
        Write-Log "# Zone: $($entry.GroupName)"            -Color Magenta
        Write-Log "########################################" -Color Magenta
        $prevGroup = $entry.GroupName
    }

    Write-Log "--- $($entry.ComputerName) ---" -Color Cyan

    if ($entry.Job.State -ne 'Completed') {
        $err    = $entry.Job.ChildJobs[0].Error | Select-Object -First 1
        $errMsg = if ($err) { $err.Exception.Message } else { "Unreachable or access denied." }
        Write-Log "  FAILED to connect: $errMsg" -Level 'ERROR' -Color Red

        $allResults.Add([pscustomobject]@{
            Zone                    = $entry.GroupName
            ComputerName            = $entry.ComputerName
            ContentServerInstance   = 'N/A'
            ContentServerDir        = 'N/A'
            AgentServiceName        = 'N/A'
            AgentDisplayName        = 'N/A'
            AgentStatus             = 'UNREACHABLE'
            AgentStartType          = 'N/A'
            AgentVersion            = 'N/A'
            AgentInstallPath        = 'N/A'
            AgentExePath            = 'N/A'
            AgentDataPath           = 'N/A'
            AgentConfigPath         = 'N/A'
            AgentAccountName        = 'N/A'
            AgentPID                = 'N/A'
            Errors                  = $errMsg
        })
        continue
    }

    $r = $entry.Job | Receive-Job
    $r.Zone = $entry.GroupName

    # Warn messages from remote
    $r.Errors | ForEach-Object { Write-Log "  $_" -Level 'WARN' -Color Yellow }

    # Console summary
    $agentColor = switch ($r.AgentStatus) {
        'Running'       { 'Green'  }
        'Stopped'       { 'Red'    }
        'NOT INSTALLED' { 'Yellow' }
        default         { 'Gray'   }
    }

    Write-Log "  Content Server Instance : $($r.ContentServerInstance)"   -Color Gray
    Write-Log "  Content Server Dir      : $($r.ContentServerDir)"        -Color Gray
    Write-Log "  Agent Service Name      : $($r.AgentServiceName)"        -Color Gray
    Write-Log "  Agent Display Name      : $($r.AgentDisplayName)"        -Color Gray
    Write-Log "  Agent Status            : $($r.AgentStatus)"             -Color $agentColor
    Write-Log "  Agent Start Type        : $($r.AgentStartType)"          -Color Gray
    Write-Log "  Agent Version           : $($r.AgentVersion)"            -Color Gray
    Write-Log "  Agent Install Path      : $($r.AgentInstallPath)"        -Color Gray
    Write-Log "  Agent Exe Path          : $($r.AgentExePath)"            -Color Gray
    Write-Log "  Agent Data Path         : $($r.AgentDataPath)"           -Color Gray
    Write-Log "  Agent Config Path       : $($r.AgentConfigPath)"         -Color Gray
    Write-Log "  Agent Account           : $($r.AgentAccountName)"        -Color Gray
    Write-Log "  Agent PID               : $($r.AgentPID)"                -Color Gray
    Write-Log -Spacer

    $allResults.Add([pscustomobject]@{
        Zone                    = $r.Zone
        ComputerName            = $r.ComputerName
        ContentServerInstance   = $r.ContentServerInstance
        ContentServerDir        = $r.ContentServerDir
        AgentServiceName        = $r.AgentServiceName
        AgentDisplayName        = $r.AgentDisplayName
        AgentStatus             = $r.AgentStatus
        AgentStartType          = $r.AgentStartType
        AgentVersion            = $r.AgentVersion
        AgentInstallPath        = $r.AgentInstallPath
        AgentExePath            = $r.AgentExePath
        AgentDataPath           = $r.AgentDataPath
        AgentConfigPath         = $r.AgentConfigPath
        AgentAccountName        = $r.AgentAccountName
        AgentPID                = $r.AgentPID
        Errors                  = ($r.Errors -join ' | ')
    })
}

$jobs | ForEach-Object { $_.Job | Remove-Job -Force }

# --- Export CSV ---
$allResults | Export-Csv -Path $csvPath -NoTypeInformation -Encoding UTF8
Write-Log "CSV exported : $csvPath" -Color Green

# --- Summary table to console ---
Write-Log -Spacer
Write-Log "========== AUDIT SUMMARY ==========" -Color Cyan
$allResults | Format-Table -AutoSize `
    Zone, ComputerName, ContentServerInstance, AgentStatus, AgentVersion, AgentInstallPath `
    | Out-String | ForEach-Object { Write-Host $_ -ForegroundColor Gray }

$endTime = Get-Date
$dur     = $endTime - $startTime
Write-Log "========================================" -Color Cyan
Write-Log "Completed : $($endTime.ToString('yyyy-MM-dd HH:mm:ss'))" -Color Cyan
Write-Log "Duration  : $($dur.ToString('mm\:ss'))"                  -Color Cyan
Write-Log "========================================" -Color Cyan
Write-Log "Log saved : $localLogPath" -Color Green
Write-Log "CSV saved : $csvPath"      -Color Green
Write-Log "---------------- SCOM AGENT AUDIT FINISHED ----------------"
#endregion
